# {{ ansible_managed }}
# Apache Kafka KRaft Server Properties（无 ZooKeeper）
# 由 Ansible 管理 - 环境: {{ env | default('production') }}

# ===== 节点标识 =====
node.id={{ kafka_broker_id | default(1) }}

# ===== 角色与控制器仲裁 =====
process.roles=broker,controller
controller.quorum.voters={% for host in groups['kafka_brokers'] %}{{ hostvars[host]['kafka_broker_id'] }}@{{ hostvars[host]['ansible_host'] }}:{{ kafka_controller_port | default(9093) }}{% if not loop.last %},{% endif %}{% endfor %}

# ===== 网络监听 =====
listeners=PLAINTEXT://0.0.0.0:{{ kafka_port | default(9092) }},CONTROLLER://0.0.0.0:{{ kafka_controller_port | default(9093) }}
advertised.listeners=PLAINTEXT://{{ ansible_host }}:{{ kafka_port | default(9092) }}
inter.broker.listener.name=PLAINTEXT
listener.security.protocol.map=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

# ===== 线程与性能 =====
num.network.threads={{ kafka_network_threads | default(3) }}
num.io.threads={{ kafka_io_threads | default(8) }}
socket.send.buffer.bytes={{ kafka_socket_send_buffer_bytes | default(102400) }}
socket.receive.buffer.bytes={{ kafka_socket_receive_buffer_bytes | default(102400) }}
socket.request.max.bytes={{ kafka_socket_request_max_bytes | default(104857600) }}

# ===== 日志存储 =====
log.dirs={{ kafka_data_dir | default(base_data_dir + '/kafka') }}
num.partitions={{ kafka_num_partitions | default(8) }}
num.recovery.threads.per.data.dir={{ kafka_num_recovery_threads_per_data_dir | default(1) }}

# ===== 副本与一致性 =====
offsets.topic.replication.factor={{ kafka_offsets_topic_replication_factor | default(3) }}
transaction.state.log.replication.factor={{ kafka_transaction_state_log_replication_factor | default(3) }}
transaction.state.log.min.isr={{ kafka_transaction_state_log_min_isr | default(2) }}
default.replication.factor={{ kafka_default_replication_factor | default(3) }}
min.insync.replicas={{ kafka_min_insync_replicas | default(2) }}

# ===== 日志保留 =====
log.retention.hours={{ kafka_log_retention_hours | default(168) }}
log.segment.bytes={{ kafka_log_segment_bytes | default(1073741824) }}
log.retention.check.interval.ms={{ kafka_log_retention_check_interval_ms | default(300000) }}

# ===== 其他 =====
group.min.session.timeout.ms=6000
group.max.session.timeout.ms=60000
delete.topic.enable=true
auto.create.topics.enable=false
compression.type=producer