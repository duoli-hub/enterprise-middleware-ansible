# {{ ansible_managed }}
# MySQL 配置文件 - 由 Ansible 管理
# 架构模式: {{ mysql_architecture | default('standalone') }} 
# 数据库版本: {{ mysql_version | default('8.0') }}

[client]
port                           = {{ mysql_port | default(3306) }}
socket                         = {{ mysql_socket | default('/var/run/mysqld/mysqld.sock') }}
default-character-set          = {{ mysql_character_set_server | default('utf8mb4') }}

[mysqld]
# ===== 基础配置 =====
user                           = {{ mysql_user | default(middleware_user) }}
port                           = {{ mysql_port | default(3306) }}
bind-address                   = 0.0.0.0
basedir                        = {{ mysql_basedir }}
datadir                        = {{ mysql_datadir }}
socket                         = {{ mysql_socket | default('/var/run/mysqld/mysqld.sock') }}
pid-file                       = {{ mysql_pidfile | default('/var/run/mysqld/mysqld.pid') }}
log-error                      = {{ mysql_log_error | default(mysql_logdir + '/error.log') }}

# ===== 字符集 =====
character-set-server           = {{ mysql_character_set_server | default('utf8mb4') }}
collation-server               = {{ mysql_collation_server | default('utf8mb4_general_ci') }}

# ===== 连接与线程 =====
max_connections                = {{ mysql_max_connections | default(2000) }}
max_user_connections           = {{ mysql_max_user_connections | default(1900) }}
max_connect_errors             = {{ mysql_max_connect_errors | default(200) }}
connect_timeout                = 10
wait_timeout                   = {{ mysql_wait_timeout | default(28800) }}
interactive_timeout            = {{ mysql_interactive_timeout | default(28800) }}
thread_cache_size              = 100
back_log                       = 500

# ===== 网络 =====
skip-name-resolve              = {{ mysql_skip_name_resolve | default(1) }}
max_allowed_packet             = 64M

# ===== 缓冲区 & 临时表 =====
key_buffer_size                = {{ mysql_key_buffer_size | default('256M') }}
sort_buffer_size               = {{ mysql_sort_buffer_size | default('4M') }}
read_buffer_size               = {{ mysql_read_buffer_size | default('2M') }}
read_rnd_buffer_size           = {{ mysql_read_rnd_buffer_size | default('16M') }}
join_buffer_size               = 4M
tmp_table_size                 = 64M
max_heap_table_size            = 64M
table_open_cache               = {{ mysql_table_open_cache | default(4096) }}
table_definition_cache         = 2048

# ===== SQL 模式 =====
sql_mode                       = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# ===== 二进制日志 =====
server-id                      = {{ mysql_server_id }}
log-bin                        = {{ mysql_logdir }}/mysql-bin
binlog_format                  = {{ mysql_binlog_format | default('ROW') }}
sync_binlog                    = {{ mysql_sync_binlog | default(1) }}
expire_logs_days               = {{ mysql_expire_logs_days | default(7) }}
max_binlog_size                = {{ mysql_max_binlog_size | default('1G') }}
binlog_cache_size              = {{ mysql_binlog_cache_size | default('4M') }}
binlog_expire_logs_seconds     = {{ (mysql_expire_logs_days | default(7) | int * 86400) }}   # 自动转换

# ===== GTID 复制 =====
{% if mysql_architecture in ['master_slave', 'mha'] %}
gtid-mode                      = {{ mysql_gtid_mode | default('ON') }}
enforce-gtid-consistency       = {{ mysql_enforce_gtid_consistency | default('ON') }}
log-slave-updates              = {{ mysql_log_slave_updates | default('ON') }}
{% endif %}

# ===== 主从角色配置 =====
{% if mysql_architecture in ['master_slave', 'mha'] %}
  {% if 'mysql_master' in group_names %}
# 主库专用
  {% else %}
# 从库专用
read_only                      = 1
super_read_only                = 1
relay_log                      = {{ mysql_logdir }}/relay-bin
relay_log_purge                = 1
relay_log_recovery             = ON
sync_relay_log                 = 1000
skip-slave-start               = 1
  {% endif %}
{% endif %}

# ===== InnoDB 配置 =====
default-storage-engine         = {{ mysql_default_storage_engine | default('InnoDB') }}
innodb_buffer_pool_size        = {{ mysql_innodb_buffer_pool_size | default('4G') }}
innodb_buffer_pool_instances   = {{ mysql_innodb_buffer_pool_instances | default(8) }}
innodb_log_file_size           = {{ mysql_innodb_log_file_size | default('2G') }}
innodb_log_files_in_group      = 2
innodb_flush_log_at_trx_commit = {{ mysql_innodb_flush_log_at_trx_commit | default(1) }}
innodb_flush_method            = {{ mysql_innodb_flush_method | default('O_DIRECT') }}
innodb_io_capacity             = {{ mysql_innodb_io_capacity | default(2000) }}
innodb_io_capacity_max         = {{ mysql_innodb_io_capacity_max | default(4000) }}
innodb_thread_concurrency      = {{ mysql_innodb_thread_concurrency | default(0) }}
innodb_read_io_threads         = {{ mysql_innodb_read_io_threads | default(8) }}
innodb_write_io_threads        = {{ mysql_innodb_write_io_threads | default(8) }}
innodb_file_per_table          = {{ mysql_innodb_file_per_table | default(1) }}
innodb_open_files              = {{ mysql_innodb_open_files | default(65535) }}
innodb_lock_wait_timeout       = {{ mysql_innodb_lock_wait_timeout | default(50) }}
innodb_autoinc_lock_mode       = 2
innodb_flush_neighbors         = 0
innodb_sort_buffer_size        = 67108864
innodb_purge_threads           = 4
innodb_print_all_deadlocks     = 1

# ===== 性能监控 =====
performance_schema             = 1

# ===== 慢查询日志 =====
slow_query_log                 = {{ mysql_slow_query_log | default(1) }}
slow_query_log_file            = {{ mysql_slow_query_log_file | default(mysql_logdir + '/slow.log') }}
long_query_time                = {{ mysql_long_query_time | default(2) }}
log_queries_not_using_indexes  = 0
log_throttle_queries_not_using_indexes = 60

# ===== 安全 =====
local_infile                   = {{ mysql_local_infile | default(0) }}
# plugin-load-add               = validate_password.so  # 如需密码策略可启用

# ===== 系统变量 =====
open_files_limit               = 65535

[mysqldump]
quick
max_allowed_packet             = 64M

[mysql]
no-auto-rehash
prompt                         = "\\u@\\h : \\d > "