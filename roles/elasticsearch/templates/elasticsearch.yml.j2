# {{ ansible_managed }}
# Elasticsearch 配置文件 - 由 Ansible 管理
# 节点: {{ inventory_hostname }} | 集群: {{ elasticsearch_cluster_name }}

cluster.name: {{ elasticsearch_cluster_name }}
node.name: {{ elasticsearch_node_name | default(inventory_hostname) }}

{% if elasticsearch_node_roles is defined and elasticsearch_node_roles | length > 0 %}
node.roles: [ {{ elasticsearch_node_roles | join(', ') }} ]
{% else %}
node.roles: [ master, data, ingest ]
{% endif %}

path.data: {{ elasticsearch_data_dir }}
path.logs: {{ elasticsearch_log_dir }}

network.host: {{ elasticsearch_http_host | default('0.0.0.0') }}
http.port: {{ elasticsearch_http_port | default(9200) }}
transport.port: {{ elasticsearch_transport_port | default(9300) }}
{% if elasticsearch_publish_host is defined %}
network.publish_host: {{ elasticsearch_publish_host }}
{% endif %}

{% if elasticsearch_architecture == 'cluster' %}
discovery.seed_hosts:
{% for host in groups['elasticsearch'] %}
  - {{ hostvars[host]['ansible_host'] }}:{{ elasticsearch_transport_port | default(9300) }}
{% endfor %}

cluster.initial_master_nodes:
{% for host in groups['elasticsearch'] %}
  - {{ hostvars[host]['inventory_hostname'] }}
{% endfor %}
{% else %}
discovery.type: single-node
{% endif %}

# 安全
xpack.security.enabled: {{ elasticsearch_xpack_security_enabled | default(true) | lower }}
xpack.security.transport.ssl.enabled: {{ elasticsearch_xpack_security_transport_ssl_enabled | default(true) | lower }}
{% if elasticsearch_xpack_security_enabled | default(true) %}
xpack.security.http.ssl.enabled: {{ elasticsearch_xpack_security_http_ssl_enabled | default(false) | lower }}
{% endif %}

# 索引与内存
indices.memory.index_buffer_size: {{ elasticsearch_indices_memory_index_buffer_size | default('20%') }}
indices.recovery.max_bytes_per_sec: {{ elasticsearch_indices_recovery_max_bytes_per_sec | default('200mb') }}
indices.queries.cache.size: {{ elasticsearch_indices_queries_cache_size | default('10%') }}
indices.fielddata.cache.size: {{ elasticsearch_indices_fielddata_cache_size | default('20%') }}
indices.requests.cache.size: {{ elasticsearch_indices_requests_cache_size | default('1%') }}

# 分片与恢复
cluster.routing.allocation.enable: {{ elasticsearch_cluster_routing_allocation_enable | default('all') }}
cluster.routing.allocation.node_concurrent_recoveries: {{ elasticsearch_cluster_routing_allocation_node_concurrent_recoveries | default(2) }}
cluster.routing.allocation.node_initial_primaries_recoveries: {{ elasticsearch_cluster_routing_allocation_node_initial_primaries_recoveries | default(4) }}

# 节点恢复
gateway.recover_after_nodes: {{ elasticsearch_gateway_recover_after_nodes | default(2) }}
gateway.expected_nodes: {{ elasticsearch_gateway_expected_nodes | default(groups['elasticsearch'] | length) }}
gateway.recover_after_time: {{ elasticsearch_gateway_recover_after_time | default('5m') }}

# 线程池
thread_pool.write.size: {{ elasticsearch_thread_pool_write_size | default(ansible_processor_cores) }}
thread_pool.search.size: {{ elasticsearch_thread_pool_search_size | default(ansible_processor_cores) }}

# 慢查询日志
index.search.slowlog.threshold.query.warn: {{ elasticsearch_slowlog_index_search_threshold_query_warn | default('5s') }}
index.search.slowlog.threshold.query.info: {{ elasticsearch_slowlog_index_search_threshold_query_info | default('2s') }}
index.indexing.slowlog.threshold.index.warn: {{ elasticsearch_slowlog_index_indexing_threshold_index_warn | default('5s') }}
index.indexing.slowlog.threshold.index.info: {{ elasticsearch_slowlog_index_indexing_threshold_index_info | default('2s') }}

# 磁盘水位线
cluster.routing.allocation.disk.watermark.low: {{ elasticsearch_cluster_routing_allocation_disk_watermark_low | default('85%') }}
cluster.routing.allocation.disk.watermark.high: {{ elasticsearch_cluster_routing_allocation_disk_watermark_high | default('90%') }}
cluster.routing.allocation.disk.watermark.flood_stage: {{ elasticsearch_cluster_routing_allocation_disk_watermark_flood_stage | default('95%') }}