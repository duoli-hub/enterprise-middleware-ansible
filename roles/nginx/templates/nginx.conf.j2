# {{ ansible_managed }}
# Nginx 主配置文件 - 由 Ansible 管理
# 架构: {{ nginx_architecture }} | 安装方式: {{ nginx_install_method }}

user  {{ nginx_user }};
worker_processes  {{ nginx_worker_processes | default('auto') }};

error_log  {{ nginx_log_dir }}/error.log {{ nginx_error_log_level | default('warn') }};
pid        {{ nginx_pid_dir | default('/run') }}/nginx.pid;

events {
    worker_connections  {{ nginx_worker_connections | default(65535) }};
    multi_accept        {{ nginx_multi_accept | default('on') }};
    use                 {{ nginx_use | default('epoll') }};
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log  {{ nginx_log_dir }}/access.log main buffer=32k flush=5s;

    sendfile            {{ nginx_sendfile | default('on') }};
    tcp_nopush          {{ nginx_tcp_nopush | default('on') }};
    tcp_nodelay         {{ nginx_tcp_nodelay | default('on') }};
    keepalive_timeout   {{ nginx_keepalive_timeout | default(65) }};
    types_hash_max_size {{ nginx_types_hash_max_size | default(2048) }};
    server_tokens       {{ nginx_server_tokens | default('off') }};

    server_names_hash_bucket_size {{ nginx_server_names_hash_bucket_size | default(128) }};
    client_max_body_size          {{ nginx_client_max_body_size | default('100m') }};
    client_body_buffer_size       {{ nginx_client_body_buffer_size | default('128k') }};
    client_header_buffer_size     {{ nginx_client_header_buffer_size | default('4k') }};
    large_client_header_buffers   {{ nginx_large_client_header_buffers | default('4 32k') }};
    output_buffers                {{ nginx_output_buffers | default('2 32k') }};
    postpone_output               {{ nginx_postpone_output | default(1460) }};

    # Gzip 压缩
    gzip              {{ nginx_gzip.enabled | default('on') }};
    gzip_min_length   {{ nginx_gzip.min_length | default(1000) }};
    gzip_comp_level   {{ nginx_gzip.comp_level | default(5) }};
    gzip_types        {{ nginx_gzip.types | default('text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript') }};
    gzip_vary         {{ nginx_gzip.vary | default('on') }};
    gzip_disable      "{{ nginx_gzip.disable | default('msie6') }}";

    # 状态监控
    {% if nginx_status_enabled | default(false) %}
    server {
        listen 127.0.0.1:8080;
        server_name localhost;
        location {{ nginx_status_location | default('/nginx_status') }} {
            stub_status on;
            access_log off;
            allow 127.0.0.1;
            {% if nginx_status_allow is defined %}
            allow {{ nginx_status_allow }};
            {% endif %}
            deny all;
        }
    }
    {% endif %}

    # 上游服务器组（负载均衡使用）
    {% if nginx_upstreams is defined and nginx_upstreams | length > 0 %}
    {% for upstream in nginx_upstreams %}
    upstream {{ upstream.name }} {
        {% if upstream.algorithm == 'least_conn' %}
        least_conn;
        {% elif upstream.algorithm == 'ip_hash' %}
        ip_hash;
        {% else %}
        # round robin (default)
        {% endif %}
        {% for server in upstream.servers %}
        server {{ server.address }}:{{ server.port }} weight={{ server.weight | default(1) }} max_fails={{ server.max_fails | default(3) }} fail_timeout={{ server.fail_timeout | default('30s') }};
        {% endfor %}
    }
    {% endfor %}
    {% endif %}

    # 包含 conf.d 目录下的所有站点配置
    include {{ nginx_conf_dir | default('/etc/nginx') }}/conf.d/*.conf;
}